              "host": ["{{base_url}}"],
              "path": ["api", "v1", "machines"],
              "query": [
                {"key": "limit", "value": "100"},
                {"key": "offset", "value": "0"},
                {"key": "status", "value": "active", "disabled": true},
                {"key": "building", "value": "Engineering", "disabled": true},
                {"key": "room", "value": "301", "disabled": true},
                {"key": "tags", "value": "Production", "disabled": true}
              ]
            },
            "description": "Get list of all machines with optional filtering"
